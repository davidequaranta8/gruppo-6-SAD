<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    AutoPlaylistDialog.fxml — Dialogo per generare automaticamente
    una playlist in base a Genere o Anno di pubblicazione.
-->
<DialogPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="group6.java.group6.controllers.AutoPlaylistDialogController"
            prefWidth="400"
            stylesheets="@app.css">

    <fx:define>
        <ToggleGroup fx:id="criterionGroup"/>
    </fx:define>

    <header>
        <Label text="Genera Playlist Automatica" styleClass="dialog-title"/>
    </header>

    <content>
        <VBox spacing="14">
            <padding><Insets top="8" bottom="8"/></padding>

            <!-- Criterio di generazione -->
            <Label text="Criterio" styleClass="form-section-label"/>
            <HBox spacing="20">
                <RadioButton fx:id="byGenreRadio"
                             text="Per Genere"
                             toggleGroup="$criterionGroup"
                             selected="true"
                             onAction="#handleCriterionChange"/>
                <RadioButton fx:id="byYearRadio"
                             text="Per Anno"
                             toggleGroup="$criterionGroup"
                             onAction="#handleCriterionChange"/>
                <RadioButton fx:id="byTagRadio"
                             text="Per Tag"
                             toggleGroup="$criterionGroup"
                             onAction="#handleCriterionChange"/>
            </HBox>

            <Separator/>

            <!-- Pannello Genere -->
            <VBox fx:id="genrePane" spacing="8">
                <Label text="Genere" styleClass="form-label"/>
                <ComboBox fx:id="genreCombo"
                          promptText="Seleziona genere…"
                          maxWidth="Infinity"/>
            </VBox>

            <!-- Pannello Anno (nascosto di default) -->
            <VBox fx:id="yearPane" spacing="8" managed="false" visible="false">
                <Label text="Anno" styleClass="form-label"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Da:"/>
                    <Spinner fx:id="yearFromSpinner" min="1900" max="2099" initialValue="2000" editable="true" prefWidth="90"/>
                    <Label text="A:"/>
                    <Spinner fx:id="yearToSpinner"   min="1900" max="2099" initialValue="2024" editable="true" prefWidth="90"/>
                </HBox>
            </VBox>

            <!-- Pannello Tag (nascosto di default) -->
            <VBox fx:id="tagPane" spacing="8" managed="false" visible="false">
                <Label text="Tag" styleClass="form-label"/>
                <HBox spacing="16">
                    <CheckBox fx:id="tagPreferiti"  text="Preferiti"/>
                    <CheckBox fx:id="tagChill"      text="Chill"/>
                    <CheckBox fx:id="tagAllenamento" text="Allenamento"/>
                </HBox>
            </VBox>

            <Separator/>

            <!-- Nome della nuova playlist -->
            <Label text="Nome playlist generata *" styleClass="form-label"/>
            <TextField fx:id="playlistNameField"
                       promptText="Es. Rock - Playlist Auto"
                       maxWidth="Infinity"/>

            <Label fx:id="errorLabel"
                   text=""
                   styleClass="error-label"
                   managed="false" visible="false"/>
        </VBox>
    </content>

    <buttonTypes>
        <ButtonType buttonData="OK_DONE"     text="Genera"/>
        <ButtonType buttonData="CANCEL_CLOSE" text="Annulla"/>
    </buttonTypes>

</DialogPane>
