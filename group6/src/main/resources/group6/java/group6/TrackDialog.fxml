<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    TrackDialog.fxml — Dialogo per aggiungere o modificare una traccia
    Usato sia in modalità "Nuova Traccia" sia "Modifica Traccia".
    Il titolo della finestra viene impostato dal controller.
-->
<DialogPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="group6.java.group6.controllers.TrackDialogController"
            prefWidth="420"
            styleClass="dialog-pane"
            stylesheets="@app.css">

    <header>
        <Label fx:id="dialogTitle" text="Nuova Traccia" styleClass="dialog-title"/>
    </header>

    <content>
        <VBox spacing="14">
            <padding><Insets top="8" bottom="8"/></padding>

            <GridPane hgap="12" vgap="12">

                <!-- Titolo -->
                <Label text="Titolo *"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"
                       styleClass="form-label"/>
                <TextField fx:id="titleField"
                           promptText="Es. Bohemian Rhapsody"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"
                           GridPane.hgrow="ALWAYS"
                           maxWidth="Infinity"/>

                <!-- Autore -->
                <Label text="Autore *"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"
                       styleClass="form-label"/>
                <TextField fx:id="authorField"
                           promptText="Es. Queen"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"
                           maxWidth="Infinity"/>

                <!-- Genere -->
                <Label text="Genere *"
                       GridPane.columnIndex="0" GridPane.rowIndex="2"
                       styleClass="form-label"/>
                <ComboBox fx:id="genreCombo"
                          promptText="Seleziona o scrivi…"
                          editable="true"
                          GridPane.columnIndex="1" GridPane.rowIndex="2"
                          maxWidth="Infinity"/>

                <!-- Anno -->
                <Label text="Anno *"
                       GridPane.columnIndex="0" GridPane.rowIndex="3"
                       styleClass="form-label"/>
                <Spinner fx:id="yearSpinner"
                         min="1900" max="2099" initialValue="2024"
                         editable="true"
                         GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <!-- Durata -->
                <Label text="Durata (mm:ss) *"
                       GridPane.columnIndex="0" GridPane.rowIndex="4"
                       styleClass="form-label"/>
                <TextField fx:id="lengthField"
                           promptText="Es. 3:45"
                           GridPane.columnIndex="1" GridPane.rowIndex="4"
                           maxWidth="120"/>

                <!-- colonne responsive -->
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="120" hgrow="NEVER"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
            </GridPane>

            <Separator/>

            <!-- Tag visivi -->
            <Label text="Tag visivi" styleClass="form-section-label"/>
            <HBox spacing="20">
                <CheckBox fx:id="tagFavourite"  text="⭐ Preferita"/>
                <CheckBox fx:id="tagExplicit"   text="🅴 Esplicita"/>
                <CheckBox fx:id="tagNewRelease" text="🆕 Nuova uscita"/>
            </HBox>

            <!-- Messaggio di errore (nascosto di default) -->
            <Label fx:id="errorLabel"
                   text=""
                   styleClass="error-label"
                   managed="false" visible="false"/>
        </VBox>
    </content>

    <buttonTypes>
        <ButtonType fx:id="saveBtn"   buttonData="OK_DONE"     text="Salva"/>
        <ButtonType fx:id="cancelBtn" buttonData="CANCEL_CLOSE" text="Annulla"/>
    </buttonTypes>

</DialogPane>
