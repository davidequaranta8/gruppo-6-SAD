<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<!--
    MainView.fxml — Finestra principale del Music Playlist Manager
    Layout: SplitPane orizzontale
      LEFT  : lista playlist + bottone nuova playlist
      CENTER: tracce della playlist selezionata + player bar in basso
      RIGHT : (opzionale) dettaglio traccia selezionata
-->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="group6.java.group6.MainController"
            prefWidth="1100" prefHeight="700"
            styleClass="root-pane"
            stylesheets="@app.css">

    <fx:define>
        <ToggleGroup fx:id="playModeGroup"/>
    </fx:define>

    <!-- ═══════════════════════════════════════════════
         TOP — Barra di navigazione / intestazione
    ═══════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>

            <Label text="🎵 Music Playlist Manager" styleClass="app-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Ricerca globale -->
            <TextField fx:id="searchField"
                       promptText="Cerca tracce o playlist…"
                       prefWidth="240"
                       styleClass="search-field"/>

            <!-- Undo -->
            <Button fx:id="undoBtn" text="↩ Annulla"
                    onAction="#handleUndo"
                    styleClass="btn-secondary"
                    disable="true"/>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════
         CENTER — SplitPane principale
    ═══════════════════════════════════════════════ -->
    <center>
        <SplitPane dividerPositions="0.25, 0.75" orientation="HORIZONTAL">

            <!-- ────────────────────────────────────────
                 PANNELLO SINISTRO — Playlist
            ──────────────────────────────────────── -->
            <VBox styleClass="sidebar" minWidth="200" prefWidth="240">
                <padding><Insets top="12" right="8" bottom="8" left="8"/></padding>

                <Label text="LE MIE PLAYLIST" styleClass="section-label"/>

                <!-- Lista playlist -->
                <ListView fx:id="playlistListView"
                          VBox.vgrow="ALWAYS"
                          styleClass="playlist-list"/>

                <Separator/>

                <!-- Sezione playlist automatiche -->
                <Label text="PLAYLIST AUTOMATICHE" styleClass="section-label"/>
                <ListView fx:id="autoPlaylistListView"
                          prefHeight="120"
                          styleClass="playlist-list"/>

                <Separator/>

                <!-- Azioni playlist -->
                <VBox spacing="6">
                    <padding><Insets top="8"/></padding>
                    <Button text="＋ Nuova Playlist"
                            fx:id="newPlaylistBtn"
                            maxWidth="Infinity"
                            onAction="#handleNewPlaylist"
                            styleClass="btn-primary"/>
                    <Button text="🔀 Genera da Genere"
                            maxWidth="Infinity"
                            onAction="#handleGenerateByGenre"
                            styleClass="btn-secondary"/>
                    <Button text="📅 Genera da Anno"
                            maxWidth="Infinity"
                            onAction="#handleGenerateByYear"
                            styleClass="btn-secondary"/>
                </VBox>
            </VBox>

            <!-- ────────────────────────────────────────
                 PANNELLO CENTRALE — Tracce + Player
            ──────────────────────────────────────── -->
            <VBox SplitPane.resizableWithParent="true" styleClass="main-panel">

                <!-- Intestazione playlist selezionata -->
                <HBox styleClass="playlist-header" alignment="CENTER_LEFT" spacing="10">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <Label fx:id="playlistNameLabel"
                           text="Nessuna playlist selezionata"
                           styleClass="playlist-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="▶ Riproduci Tutto"
                            fx:id="playAllBtn"
                            onAction="#handlePlayAll"
                            styleClass="btn-play"
                            disable="true"/>
                    <Button text="🔀 Shuffle"
                            fx:id="shuffleBtn"
                            onAction="#handleShuffle"
                            styleClass="btn-secondary"
                            disable="true"/>
                    <Button text="✏️ Rinomina"
                            fx:id="renamePlaylistBtn"
                            onAction="#handleRenamePlaylist"
                            styleClass="btn-secondary"
                            disable="true"/>
                    <Button text="🗑 Elimina"
                            fx:id="deletePlaylistBtn"
                            onAction="#handleDeletePlaylist"
                            styleClass="btn-danger"
                            disable="true"/>
                </HBox>

                <!-- Filtri tracce -->
                <HBox styleClass="filter-bar" spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
                    <Label text="Filtra:" styleClass="filter-label"/>
                    <ComboBox fx:id="genreFilter"
                              promptText="Genere"
                              prefWidth="130"
                              onAction="#handleFilter"/>
                    <ComboBox fx:id="yearFilter"
                              promptText="Anno"
                              prefWidth="100"
                              onAction="#handleFilter"/>
                    <Button text="✕ Reset"
                            onAction="#handleResetFilter"
                            styleClass="btn-link"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="＋ Aggiungi Traccia"
                            fx:id="addTrackBtn"
                            onAction="#handleAddTrack"
                            styleClass="btn-primary"
                            disable="true"/>
                </HBox>

                <!-- Tabella tracce -->
                <TableView fx:id="tracksTableView"
                           VBox.vgrow="ALWAYS"
                           styleClass="tracks-table">
                    <columns>
                        <TableColumn fx:id="colNow"     text="#"        prefWidth="36"  sortable="false"/>
                        <TableColumn fx:id="colTitle"   text="Titolo"   prefWidth="220"/>
                        <TableColumn fx:id="colAuthor"  text="Autore"   prefWidth="160"/>
                        <TableColumn fx:id="colGenre"   text="Genere"   prefWidth="110"/>
                        <TableColumn fx:id="colYear"    text="Anno"     prefWidth="70"/>
                        <TableColumn fx:id="colLength"  text="Durata"   prefWidth="70"/>
                        <TableColumn fx:id="colTags"    text="Tag"      prefWidth="100" sortable="false"/>
                        <TableColumn fx:id="colActions" text=""         prefWidth="110" sortable="false"/>
                    </columns>
                    <placeholder>
                        <Label text="Nessuna traccia. Seleziona una playlist o aggiungine una." styleClass="empty-label"/>
                    </placeholder>
                </TableView>

                <!-- ─────────────────────────────────
                     HOME — Tracce più riprodotte
                     (visibile solo nella home)
                ───────────────────────────────── -->
                <VBox fx:id="homeSectionBox" styleClass="home-section" managed="false" visible="false">
                    <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                    <Label text="🔥 Più Riprodotte" styleClass="section-label"/>
                    <ListView fx:id="topTracksListView" prefHeight="120" styleClass="top-tracks-list"/>
                </VBox>

                <!-- ─────────────────────────────────
                     PLAYER BAR in basso
                ───────────────────────────────── -->
                <VBox fx:id="playerBar" styleClass="player-bar">
                    <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>

                    <!-- Progress bar -->
                    <HBox alignment="CENTER" spacing="10">
                        <Label fx:id="currentTimeLabel" text="0:00" styleClass="time-label"/>
                        <Slider fx:id="progressSlider" HBox.hgrow="ALWAYS" styleClass="progress-slider"/>
                        <Label fx:id="totalTimeLabel"   text="0:00" styleClass="time-label"/>
                    </HBox>

                    <!-- Controlli riproduzione -->
                    <HBox alignment="CENTER" spacing="16">
                        <padding><Insets top="6"/></padding>

                        <!-- Modalità riproduzione -->
                        <ToggleButton fx:id="seqBtn"     text="▶▶ Seq"   toggleGroup="$playModeGroup" styleClass="mode-btn" selected="true"/>
                        <ToggleButton fx:id="shuffleToggleBtn" text="🔀 Shuffle" toggleGroup="$playModeGroup" styleClass="mode-btn"/>
                        <ToggleButton fx:id="loopBtn"    text="🔁 Loop"  toggleGroup="$playModeGroup" styleClass="mode-btn"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Controlli -->
                        <Button fx:id="prevBtn"   text="⏮" onAction="#handlePrev"   styleClass="ctrl-btn"/>
                        <Button fx:id="playPauseBtn" text="▶" onAction="#handlePlayPause" styleClass="ctrl-btn-main"/>
                        <Button fx:id="nextBtn"   text="⏭" onAction="#handleNext"   styleClass="ctrl-btn"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Info traccia corrente -->
                        <VBox alignment="CENTER_LEFT" minWidth="200">
                            <Label fx:id="nowPlayingTitle"  text="—"    styleClass="now-title"/>
                            <Label fx:id="nowPlayingAuthor" text=""     styleClass="now-author"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ────────────────────────────────────────
                 PANNELLO DESTRO — Dettaglio traccia
                 (visibile solo quando una traccia
                  è selezionata nella tabella)
            ──────────────────────────────────────── -->
            <VBox fx:id="detailPanel"
                  styleClass="detail-panel"
                  minWidth="200" prefWidth="240">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="DETTAGLIO TRACCIA" styleClass="section-label"/>

                <GridPane styleClass="detail-grid" hgap="8" vgap="8">
                    <padding><Insets top="12"/></padding>
                    <Label text="Titolo:"   GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="detail-key"/>
                    <Label fx:id="detailTitle"  GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="detail-value"/>

                    <Label text="Autore:"   GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="detail-key"/>
                    <Label fx:id="detailAuthor" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="detail-value"/>

                    <Label text="Genere:"   GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="detail-key"/>
                    <Label fx:id="detailGenre"  GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="detail-value"/>

                    <Label text="Anno:"     GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="detail-key"/>
                    <Label fx:id="detailYear"   GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="detail-value"/>

                    <Label text="Durata:"   GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="detail-key"/>
                    <Label fx:id="detailLength" GridPane.columnIndex="1" GridPane.rowIndex="4" styleClass="detail-value"/>
                </GridPane>

                <Separator>
                    <VBox.margin><Insets top="12" bottom="12"/></VBox.margin>
                </Separator>

                <Label text="TAG VISIVI" styleClass="section-label"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="8"/></padding>
                    <CheckBox fx:id="tagFavourite" text="⭐ Preferita"  onAction="#handleTagChange"/>
                    <CheckBox fx:id="tagExplicit"  text="🅴 Esplicita"  onAction="#handleTagChange"/>
                    <CheckBox fx:id="tagNewRelease" text="🆕 Novità"   onAction="#handleTagChange"/>
                </HBox>

                <Separator>
                    <VBox.margin><Insets top="12" bottom="12"/></VBox.margin>
                </Separator>

                <VBox spacing="8">
                    <Button text="✏️ Modifica Traccia"
                            maxWidth="Infinity"
                            fx:id="editTrackBtn"
                            onAction="#handleEditTrack"
                            styleClass="btn-primary"/>
                    <Button text="🗑 Rimuovi dalla Playlist"
                            maxWidth="Infinity"
                            fx:id="removeFromPlaylistBtn"
                            onAction="#handleRemoveFromPlaylist"
                            styleClass="btn-danger"/>
                    <Button text="🗑 Elimina Traccia"
                            maxWidth="Infinity"
                            fx:id="deleteTrackBtn"
                            onAction="#handleDeleteTrack"
                            styleClass="btn-danger"/>
                </VBox>
            </VBox>

        </SplitPane>
    </center>

</BorderPane>