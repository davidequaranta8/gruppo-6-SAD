@startuml ClassDiagram
' ============================================================================
'  DIAGRAMMA UML DELLE CLASSI – Music Playlist Manager (Group 6)
' ============================================================================

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 60

' ──────────────────────────────────────────────────────────────────────────────
'  ENUMERATIONS
' ──────────────────────────────────────────────────────────────────────────────
package "enumerations" #EEFFEE {

    enum GenreEnum {
        POP
        ROCK
        HIP_HOP
        JAZZ
        CLASSICAL
        ELECTRONIC
        INDIE
        METAL
        COUNTRY
        R_AND_B
        BLUES
        REGGAE
        OTHER
    }

    enum TagEnum {
        Preferiti
        Chill
        Allenamento
    }
}

' ──────────────────────────────────────────────────────────────────────────────
'  EXCEPTIONS
' ──────────────────────────────────────────────────────────────────────────────
package "exceptions" #FFEEEE {

    class DuplicatePlaylistException {
        + DuplicatePlaylistException(message : String)
    }

    class DuplicateTitleTrackException {
        + DuplicateTitleTrackException(message : String)
    }

    DuplicatePlaylistException --|> Exception
    DuplicateTitleTrackException --|> Exception
}

' ──────────────────────────────────────────────────────────────────────────────
'  MODELS
' ──────────────────────────────────────────────────────────────────────────────
package "models" #EEEEFF {

    class Track {
        - id : int
        - title : String
        - author : String
        - length : double
        - genre : GenreEnum
        - year : int
        - tag : TagEnum
        - countPlayed : int
        - filePath : String
        + Track(title : String, author : String, genre : GenreEnum, year : int, tag : TagEnum)
        + Track(title : String, author : String, genre : GenreEnum, year : int)
        + getId() : int
        + getTitle() : String
        + getAuthor() : String
        + getLength() : double
        + getGenre() : GenreEnum
        + getYear() : int
        + getTag() : TagEnum
        + getCountPlayed() : int
        + getFilePath() : String
        + setId(id : int) : void
        + setTitle(title : String) : void
        + setAuthor(author : String) : void
        + setLength(length : double) : void
        + setGenre(genre : GenreEnum) : void
        + setYear(year : int) : void
        + setTag(tag : TagEnum) : void
        + setCountPlayed(countPlayed : int) : void
        + setFilePath(filePath : String) : void
        + incrementCountPlayed() : void
        + updateTrack(title : String, author : String, genre : GenreEnum, year : int, tag : TagEnum) : void
        + equals(o : Object) : boolean
        + hashCode() : int
        + toString() : String
    }

    class Playlist {
        - id : int
        - title : String
        - countPlayed : int
        - tracks : Set<Track>
        + Playlist(title : String)
        + getId() : int
        + setId(id : int) : void
        + getTitle() : String
        + setTitle(title : String) : void
        + getCountPlayed() : int
        + setCountPlayed(countPlayed : int) : void
        + getTracks() : Set<Track>
        + addTrack(track : Track) : void
        + removeTrack(track : Track) : void
        + incrementCountPlayed() : void
        + equals(o : Object) : boolean
        + toString() : String
    }

    interface Library <<interface>> <<Subject>> {
        + addObserver(observer : LibraryObserver) : void
        + removeObserver(observer : LibraryObserver) : void
        + notifyObservers() : void
    }

    interface LibraryObserver <<interface>> <<Observer>> {
        + onLibraryChanged() : void
    }

    interface PlaylistObserver <<interface>> <<Observer>> {
        + onPlaylistChanged() : void
    }

    class ConcreteLibrary <<Singleton>> {
        - tracks : Set<Track>
        - {static} instance : ConcreteLibrary
        - observers : List<LibraryObserver>
        - trackDao : TrackDao
        - ConcreteLibrary()
        + {static} getInstance() : ConcreteLibrary
        + getTracks() : Set<Track>
        + setTracks(tracks : Set<Track>) : void
        + addTrack(t : Track) : void
        + updateTrack(t : Track) : void
        + removeTrack(t : Track) : void
        + addObserver(observer : LibraryObserver) : void
        + removeObserver(observer : LibraryObserver) : void
        + notifyObservers() : void
    }

    class PlaylistManager <<Singleton>> {
        - {static} instance : PlaylistManager
        - playlists : Set<Playlist>
        - observers : List<PlaylistObserver>
        - playlistDao : PlaylistDao
        - selectedPlaylist : Playlist
        - PlaylistManager()
        + {static} getInstance() : PlaylistManager
        + addObserver(observer : PlaylistObserver) : void
        + removeObserver(observer : PlaylistObserver) : void
        + notifyObservers() : void
        + createPlaylist(title : String) : Playlist
        + deletePlaylist(playlist : Playlist) : void
        + renamePlaylist(playlist : Playlist, newTitle : String) : void
        + addTrackToPlaylist(playlist : Playlist, track : Track) : void
        + removeTrackFromPlaylist(playlist : Playlist, track : Track) : void
        + loadTracksForPlaylist(playlist : Playlist) : void
        + getPlaylists() : Set<Playlist>
        + getSelectedPlaylist() : Playlist
        + setSelectedPlaylist(playlist : Playlist) : void
        + updateTrackInPlaylists(updatedTrack : Track) : void
        + removeTrackFromAllPlaylists(track : Track) : void
        - loadFromDb() : void
        - verifyDuplicateTitle(title : String, exclude : Playlist) : void
    }

    ' --- Relazioni Models ---
    ConcreteLibrary ..|> Library : implements
    Playlist "1" o-- "0..*" Track : contiene >
    ConcreteLibrary "1" o-- "0..*" Track : contiene >
    ConcreteLibrary "1" *-- "0..*" LibraryObserver : observers >
    PlaylistManager "1" *-- "0..*" PlaylistObserver : observers >
    PlaylistManager "1" o-- "0..*" Playlist : gestisce >
    PlaylistManager "1" o-- "0..1" Playlist : selectedPlaylist >
    Track --> GenreEnum : genre
    Track --> TagEnum : tag
}

' ──────────────────────────────────────────────────────────────────────────────
'  DATABASE
' ──────────────────────────────────────────────────────────────────────────────
package "db" #FFF5EE {

    class DatabaseResource <<Singleton>> {
        - {static} instance : DatabaseResource
        - sqlConnection : Connection
        - url : String
        - user : String
        - password : String
        - DatabaseResource()
        + {static} getInstance() : DatabaseResource
        + getSqlConnection() : Connection
        - initSchema() : void
    }
}

' ──────────────────────────────────────────────────────────────────────────────
'  DAO
' ──────────────────────────────────────────────────────────────────────────────
package "dao" #FFFAEE {

    interface "Dao<T, K>" as Dao <<interface>> {
        + get(key : K) : Optional<T>
        + getAll() : Set<T>
        + save(t : T) : void
        + delete(t : T) : void
        + update(t : T) : void
    }

    class TrackDao {
        - sqlConnection : Connection
        + TrackDao()
        + get(key : Integer) : Optional<Track>
        + getAll() : Set<Track>
        + save(track : Track) : void
        + delete(track : Track) : void
        + update(track : Track) : void
        + deleteAll() : void
        + existsByAuthorAndTitle(author : String, title : String) : boolean
        + existsByAuthorAndTitleAndId(author : String, title : String, id : int) : boolean
        + getTopPlayedTracks(k : int) : List<Track>
        + getAllYears() : Set<Integer>
    }

    class PlaylistDao {
        - sqlConnection : Connection
        + PlaylistDao()
        + get(id : Integer) : Optional<Playlist>
        + getAll() : Set<Playlist>
        + save(playlist : Playlist) : void
        + delete(playlist : Playlist) : void
        + update(playlist : Playlist) : void
        + incrementCountPlayed(playlist : Playlist) : void
        + deleteAll() : void
        + addTrack(playlist : Playlist, track : Track) : void
        + removeTrack(playlist : Playlist, track : Track) : void
        + loadAllTracks(playlist : Playlist) : void
    }

    TrackDao ..|> Dao : implements\n<Track, Integer>
    PlaylistDao ..|> Dao : implements\n<Playlist, Integer>
    TrackDao --> DatabaseResource : usa >
    PlaylistDao --> DatabaseResource : usa >
    TrackDao ..> Track : <<create/read>>
    PlaylistDao ..> Playlist : <<create/read>>
    PlaylistDao ..> Track : <<read>>
}

' ──────────────────────────────────────────────────────────────────────────────
'  PLAYER – Strategy Pattern
' ──────────────────────────────────────────────────────────────────────────────
package "player" #EEF5FF {

    interface PlaybackStrategy <<interface>> <<Strategy>> {
        + nextTrack(queue : List<Track>, current : Track) : Track
        + prevTrack(queue : List<Track>, current : Track) : Track
        + buildQueue(tracks : List<Track>, current : Track) : List<Track>
    }

    class SequentialStrategy {
        + nextTrack(queue : List<Track>, current : Track) : Track
        + prevTrack(queue : List<Track>, current : Track) : Track
        + buildQueue(tracks : List<Track>, current : Track) : List<Track>
    }

    class LoopStrategy {
        + nextTrack(queue : List<Track>, current : Track) : Track
        + prevTrack(queue : List<Track>, current : Track) : Track
        + buildQueue(tracks : List<Track>, current : Track) : List<Track>
    }

    class ShuffleStrategy {
        - random : Random
        - played : List<Track>
        + nextTrack(queue : List<Track>, current : Track) : Track
        + prevTrack(queue : List<Track>, current : Track) : Track
        + buildQueue(tracks : List<Track>, current : Track) : List<Track>
    }

    class AudioPlayer {
        - mediaPlayer : MediaPlayer
        - onEndCallback : Runnable
        - onTimeChanged : BiConsumer<Double, Double>
        + setOnEndOfMedia(callback : Runnable) : void
        + setOnTimeChanged(callback : BiConsumer<Double, Double>) : void
        + play(track : Track) : void
        + pause() : void
        + resume() : void
        + stop() : void
        + isPlaying() : boolean
        + isPaused() : boolean
        + seekTo(seconds : double) : void
        + getTotalDuration() : double
    }

    SequentialStrategy ..|> PlaybackStrategy
    LoopStrategy ..|> PlaybackStrategy
    ShuffleStrategy ..|> PlaybackStrategy
    AudioPlayer ..> Track : riproduce >
}

' ──────────────────────────────────────────────────────────────────────────────
'  SERVICES
' ──────────────────────────────────────────────────────────────────────────────
package "services" #FFEEFF {

    class PlayerService {
        - audioPlayer : AudioPlayer
        - trackService : TrackService
        - onTrackEnd : Runnable
        - currentTimeLabel : Label
        - totalTimeLabel : Label
        - progressSlider : Slider
        - playPauseBtn : Button
        - currentTitle : Label
        - currentAuthor : Label
        - currentPlaylist : Label
        - currentPlayingTrack : Track
        + PlayerService(trackService : TrackService, currentTimeLabel : Label, totalTimeLabel : Label, progressSlider : Slider, playPauseBtn : Button, currentTitle : Label, currentAuthor : Label, currentPlaylist : Label)
        - setupPlayerCallbacks() : void
        + handlePlayPause(selectedTrack : Track) : void
        - playNewTrack(track : Track, icon : FontIcon) : void
        + seekTrack() : void
        + stopAndClearIfPlaying(track : Track) : void
        + getCurrentPlayingTrack() : Track
        + changeTrack(newTrack : Track) : void
        + setOnTrackEnd(onTrackEnd : Runnable) : void
        + setCurrentPlaylistLabel(playlistName : String) : void
    }

    class TrackService {
        - trackDao : TrackDao
        + saveTrack(track : Track, audioFile : File) : void
        + updateTrack(track : Track, audioFile : File) : void
        + deleteTrack(track : Track) : void
        - copyFileToMusicFolder(sourceFile : File, destPath : String) : void
        - setDuration(audioFile : File, track : Track, onDisposed : Runnable) : void
        + incrementPlayCount(track : Track) : void
    }

    PlayerService *-- AudioPlayer : contiene >
    PlayerService --> TrackService : usa >
    PlayerService --> Track : currentPlayingTrack >
    TrackService --> TrackDao : usa >
    TrackService --> ConcreteLibrary : usa >
    TrackService --> PlaylistManager : usa >
}

' ──────────────────────────────────────────────────────────────────────────────
'  UTILS – Command Pattern
' ──────────────────────────────────────────────────────────────────────────────
package "utils" #FFFFEE {

    interface Command <<interface>> {
        + execute() : void
        + undo() : void
    }

    class CommandInvoker <<Invoker>> {
        - history : Stack<Command>
        + executeCommand(command : Command) : void
        + undoLastCommand() : boolean
    }

    class AddTrackCommand <<ConcreteCommand>> {
        - track : Track
        - playlist : Playlist
        + AddTrackCommand(track : Track, playlist : Playlist)
        + execute() : void
        + undo() : void
    }

    class RemoveTrackCommand <<ConcreteCommand>> {
        - track : Track
        - playlist : Playlist
        - originalPosition : int
        + RemoveTrackCommand(track : Track, playlist : Playlist)
        + execute() : void
        + undo() : void
    }

    class TrackMapper {
        + {static} extractTrackFromResultSet(rs : ResultSet) : Track
        - {static} parseGenre(value : String) : GenreEnum
    }

    class TimeUtils {
        + {static} formatTime(seconds : double) : String
        + {static} parseFormattedDuration(formattedDuration : double) : double
    }

    AddTrackCommand ..|> Command
    RemoveTrackCommand ..|> Command
    CommandInvoker "1" o-- "0..*" Command : history >
    AddTrackCommand --> PlaylistManager : usa >
    RemoveTrackCommand --> PlaylistManager : usa >
    AddTrackCommand --> Track
    AddTrackCommand --> Playlist
    RemoveTrackCommand --> Track
    RemoveTrackCommand --> Playlist
    TrackMapper ..> Track : <<create>>
    TrackMapper ..> GenreEnum
    TrackMapper ..> TagEnum
}

' ──────────────────────────────────────────────────────────────────────────────
'  CONTROLLERS – State Pattern
' ──────────────────────────────────────────────────────────────────────────────
package "controllers" #EEFFEF {

    interface ViewState <<interface>> <<State>> {
        + enter(ctx : MainViewContext) : void
        + exit(ctx : MainViewContext) : void
    }

    class LibraryState <<ConcreteState>> {
        + enter(ctx : MainViewContext) : void
        + exit(ctx : MainViewContext) : void
    }

    class PlaylistState <<ConcreteState>> {
        + enter(ctx : MainViewContext) : void
        + exit(ctx : MainViewContext) : void
    }

    class MainViewContext <<Context>> {
        + {static} LIBRARY_STATE : LibraryState
        + {static} PLAYLIST_STATE : PlaylistState
        + filterBar : HBox
        + addTrackBtn : Button
        + addToPlaylistBtn : Button
        + deleteTrackBtn : Button
        + removeFromPlaylistBtn : Button
        + playlistTitleLabel : Label
        + renamePlaylistBtn : Button
        + undoBtn : Button
        - currentState : ViewState
        + MainViewContext(filterBar : HBox, addTrackBtn : Button, addToPlaylistBtn : Button, deleteTrackBtn : Button, removeFromPlaylistBtn : Button, renamePlaylistBtn : Button, playlistTitleLabel : Label, undoBtn : Button)
        + setState(newState : ViewState) : void
        + getCurrentState() : ViewState
        + setVisible(node : Node, visible : boolean) : void
    }

    class MainController <<ConcreteObserver>> {
        - trackDao : TrackDao
        - invoker : CommandInvoker
        - trackService : TrackService
        - playerService : PlayerService
        - viewContext : MainViewContext
        - strategy : PlaybackStrategy
        - playbackQueue : List<Track>
        - activePlaylist : Playlist
        + initialize() : void
        + handleUndo() : void
        + handleNewPlaylist() : void
        + handleRenamePlaylist() : void
        + handleDeletePlaylist() : void
        + handleAddTrack() : void
        + handleEditTrack() : void
        + handleDeleteTrack() : void
        + handleAddToPlaylist() : void
        + handleRemoveFromPlaylist() : void
        + handleSearch() : void
        + handleFilter() : void
        + handleResetFilter() : void
        + handlePlayAll() : void
        + handleShuffle() : void
        + handleLoop() : void
        + handlePlayPause() : void
        + handleNext() : void
        + handlePrev() : void
        + handleTrackSelected() : void
        + handleGeneratePlaylist() : void
        + onLibraryChanged() : void
        + onPlaylistChanged() : void
    }

    class PlaylistDialogController {
        - dialogTitle : Label
        - nameField : TextField
        - errorLabel : Label
        + getName() : String
        + setName(name : String) : void
        + setDialogTitle(title : String) : void
        + validate() : boolean
        + showValidationError() : void
    }

    class TrackDialogController {
        - dialogTitle : Label
        - titleField : TextField
        - authorField : TextField
        - genreCombo : ComboBox<GenreEnum>
        - yearSpinner : Spinner<Integer>
        - starredBtn : ToggleButton
        - chillBtn : ToggleButton
        - workoutBtn : ToggleButton
        - errorLabel : Label
        - chooseFileBtn : Button
        - fileNameLabel : Label
        - selectedFile : File
        - toggleGroup : ToggleGroup
        + initialize() : void
        + getTitle() : String
        + getAuthor() : String
        + getGenre() : GenreEnum
        + getYear() : Integer
        + getTag() : TagEnum
        + getOptionSelected() : String
        + handleChooseFile(event : ActionEvent) : void
        + getSelectedFile() : File
        + setSelectedFile(file : File) : void
        + validate(isEditMode : boolean) : boolean
        + showValidationError() : void
        + setTitleField(title : String) : void
        + setAuthorField(author : String) : void
        + setGenreCombo(genre : GenreEnum) : void
        + setYearSpinner(year : Integer) : void
        + setFileNameLabel(fileName : String) : void
        + setToggleGroup(tag : TagEnum) : void
    }

    class AutoPlaylistDialogController {
        - criterionGroup : ToggleGroup
        - byGenreRadio : RadioButton
        - byYearRadio : RadioButton
        - byTagRadio : RadioButton
        - genrePane : VBox
        - genreCombo : ComboBox<String>
        - yearPane : VBox
        - yearFromSpinner : Spinner<Integer>
        - yearToSpinner : Spinner<Integer>
        - tagPane : VBox
        - tagPreferiti : CheckBox
        - tagChill : CheckBox
        - tagAllenamento : CheckBox
        - playlistNameField : TextField
        - errorLabel : Label
        + initialize() : void
        + getSelectedTags() : List<TagEnum>
        + getPlaylistName() : String
        + getPlaylistNameField() : TextField
        + isTagSelected() : boolean
        + isYearSelected() : boolean
        + isGenreSelected() : boolean
        + getSelectedGenre() : GenreEnum
        + getYearFrom() : int
        + getYearTo() : int
        + validate() : boolean
        + showValidationError() : void
        + setName(name : String) : void
    }

    LibraryState ..|> ViewState
    PlaylistState ..|> ViewState
    MainViewContext "1" o-- "1" ViewState : currentState >
    MainController ..|> LibraryObserver : implements
    MainController ..|> PlaylistObserver : implements
    MainController *-- MainViewContext : viewContext >
    MainController *-- CommandInvoker : invoker >
    MainController *-- TrackService : trackService >
    MainController *-- PlayerService : playerService >
    MainController --> PlaybackStrategy : strategy >
    MainController --> ConcreteLibrary : usa >
    MainController --> PlaylistManager : usa >
    MainController --> TrackDao : usa >
}

' ──────────────────────────────────────────────────────────────────────────────
'  APPLICATION
' ──────────────────────────────────────────────────────────────────────────────
package "app" #F5F5F5 {

    class HelloApplication {
        + start(stage : Stage) : void
    }

    class Launcher {
        + {static} main(args : String[]) : void
    }

    HelloApplication --|> Application : extends
    Launcher ..> HelloApplication : lancia >
    HelloApplication ..> DatabaseResource : inizializza >
}

' ──────────────────────────────────────────────────────────────────────────────
'  RELAZIONI CROSS-PACKAGE
' ──────────────────────────────────────────────────────────────────────────────
ConcreteLibrary *-- TrackDao : trackDao >
PlaylistManager *-- PlaylistDao : playlistDao >
TrackDao ..> TrackMapper : usa >

' ──────────────────────────────────────────────────────────────────────────────
'  NOTE SUI DESIGN PATTERN
' ──────────────────────────────────────────────────────────────────────────────
note bottom of Library
  **Observer Pattern**
  Library = Subject
  LibraryObserver = Observer
  ConcreteLibrary = ConcreteSubject
  MainController = ConcreteObserver
end note

note bottom of PlaybackStrategy
  **Strategy Pattern**
  PlaybackStrategy = Strategy
  SequentialStrategy = ConcreteStrategy
  LoopStrategy = ConcreteStrategy
  ShuffleStrategy = ConcreteStrategy
  MainController = Context
end note

note bottom of Command
  **Command Pattern**
  Command = Command
  AddTrackCommand = ConcreteCommand
  RemoveTrackCommand = ConcreteCommand
  CommandInvoker = Invoker
  MainController = Client
end note

note bottom of ViewState
  **State Pattern**
  ViewState = State
  LibraryState = ConcreteState
  PlaylistState = ConcreteState
  MainViewContext = Context
end note

note bottom of Dao
  **DAO Pattern**
  Dao<T,K> = generic interface
  TrackDao = ConcreteDAO
  PlaylistDao = ConcreteDAO
end note

note bottom of ConcreteLibrary
  **Singleton Pattern**
  ConcreteLibrary
  PlaylistManager
  DatabaseResource
end note

@enduml
